#!/usr/bin/env bash
# claude-ds — wrapper that runs `claude` against DeepSeek's Anthropic-compatible API.
#
# Config:   ${XDG_CONFIG_HOME:-$HOME/.config}/claude-ds/config
# Args:     --reset-password   re-prompt for the API key reference (then runs claude)
#           everything else is forwarded to `claude` unchanged.
#
# Supported secret-reference schemes for the API key:
#   <key>                   bare key — anything without a recognised scheme is
#                           treated as plaintext
#   op://VAULT/ITEM/FIELD   1Password CLI (`op read`)
#   system://<account>      OS keychain — macOS `security`, Linux `secret-tool`
#                           (service name: claude-ds). No widely-adopted URI standard
#                           exists for this; the scheme is local convention.
#   infisical://PROJECT_ID/ENV/PATH#KEY
#                           Infisical CLI (`infisical secrets get`). PATH is the
#                           folder namespace (`/` for root); KEY is the secret
#                           name as the URI fragment. Examples:
#                             infisical://abc123/prod/#API_KEY
#                             infisical://abc123/dev/postgres#DB_PASSWORD
#                             infisical://abc123/dev/k8s/api-keys#STRIPE
#                           Auth: either run `infisical login` interactively, or
#                           export `INFISICAL_TOKEN` (machine-identity / service
#                           token) before invoking claude-ds.
#
# The secret-handling code below the arg-parser is a self-contained, reusable
# library (BEGIN secretref … END secretref) — copy that block into any other
# wrapper, set SECRETREF_KEYCHAIN_SERVICE / SECRETREF_LOG_PREFIX, and call
# secretref_resolve / secretref_prompt / secretref_help_text / secretref_reset_local.
# Future schemes (warden://, ...) plug into secretref_resolve() inside the lib.

set -euo pipefail

VERSION="0.6.0"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-ds"
CONFIG_FILE="$CONFIG_DIR/config"
KEYCHAIN_SERVICE="claude-ds"
DEFAULT_BASE_URL="https://api.deepseek.com/anthropic"
DEFAULT_MODEL="deepseek-v4-pro"
# Config-file schema version. Bump on incompatible changes; add a migration
# entry in `migrate_config` for each step. Migrations are applied in order
# from the file's recorded version up to CURRENT_SCHEMA, with a backup
# written before any mutation.
CURRENT_SCHEMA=1
# Where to fetch the proxy script from when it is missing on disk and the
# user has the proxy enabled. Pinned to the claude-ds-0.6.0 tag; update
# this when tagging the next release.
PROXY_DOWNLOAD_URL="https://raw.githubusercontent.com/earchibald/agent-utilities/claude-ds-0.6.0/wrappers/claude-ds/claude-ds-proxy.py"
# Known config keys (used by the validator and the damaged-config repair).
# Anything in the config file outside this list is preserved with a warning.
KNOWN_CONFIG_KEYS=(
  _schema
  api_key_ref base_url model
  model_opus model_sonnet model_haiku model_small_fast
  capabilities unlock_auto_mode
  proxy_effort proxy_effort_opus proxy_effort_sonnet proxy_effort_haiku proxy_effort_small_fast
  proxy_strip_thinking proxy_bind proxy_debug
)

# Print a horizontal rule sized to the terminal width (fallback 78). Used to
# separate claude-ds-owned output from forwarded `claude` output. Uses U+2500
# BOX DRAWINGS LIGHT HORIZONTAL — a fixed-width 1-cell glyph, so it tiles
# cleanly even in pagers (less) where ambiguous-width em dash (—) can render
# as a wide character and overflow the terminal width.
print_rule() {
  local cols
  cols=$(tput cols 2>/dev/null || echo 78)
  printf '\n'
  printf -- '\xe2\x94\x80%.0s' $(seq 1 "$cols")
  printf '\n\n'
}

# ---- arg parsing: pull out our flags, forward the rest --------------------
RESET=0
DOCTOR=0
PROXY_OVERRIDE=""
PASSTHROUGH=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --reset-password|--rotate-key) RESET=1 ;;
    --doctor)                      DOCTOR=1 ;;
    --proxy-off)                   PROXY_OVERRIDE="off" ;;
    --proxy-on)                    PROXY_OVERRIDE="auto" ;;
    --proxy-on=*)                  PROXY_OVERRIDE="${1#--proxy-on=}" ;;
    --) shift; PASSTHROUGH+=("$@"); break ;;
    *) PASSTHROUGH+=("$1") ;;
  esac
  shift
done

# ---- --help / -h: print our help, then forward to `claude --help` ---------
pick_pager() {
  # Honor $PAGER if it points to a runnable command; otherwise fall back to
  # less, then more, then cat. less gets -R (preserve ANSI from claude --help)
  # and -F (skip pager if output fits one screen).
  if [[ -n "${PAGER:-}" ]] && command -v "${PAGER%% *}" >/dev/null 2>&1; then
    printf '%s' "$PAGER"
  elif command -v less >/dev/null 2>&1; then
    printf '%s' "less -RF"
  elif command -v more >/dev/null 2>&1; then
    printf '%s' "more"
  else
    printf '%s' "cat"
  fi
}

for arg in ${PASSTHROUGH[@]+"${PASSTHROUGH[@]}"}; do
  case "$arg" in
    --version|-V)
      echo "claude-ds $VERSION"
      if command -v claude >/dev/null 2>&1; then
        print_rule
        claude --version 2>&1 || true
      fi
      exit 0
      ;;
    --help|-h)
      pager=$(pick_pager)
      # Force UTF-8 so em dashes / box-drawing rules in the help body render
      # correctly under less (which otherwise defaults to latin1 and shows
      # multi-byte chars as <U+...> escapes).
      export LESSCHARSET=utf-8
      {
        cat <<'EOF'
claude-ds — wrapper that runs `claude` against DeepSeek's Anthropic-compatible API.

USAGE
  claude-ds [--rotate-key | --reset-password] [--proxy-off | --proxy-on[=<spec>]]
            [--doctor] [--help | -h] [--version | -V] [claude args...]

claude-ds-specific flags
  --rotate-key,
  --reset-password    Clear / rotate the stored API key reference. For
                      `system://` references, asks whether to (1) change the
                      key for the existing account or (2) switch to a
                      different account / scheme (with an option to delete
                      or keep the old keychain entry). For other schemes,
                      forgets the local reference (upstream stores are
                      never touched). The new key is liveness-checked
                      against the configured base_url before saving.
  --proxy-off         Disable the reasoning-effort proxy for this session.
                      Overrides both config file and env var.
  --proxy-on[=<spec>] Enable the reasoning-effort proxy for this session.
                      Default spec is `auto`; provide a custom spec after
                      `=` (e.g. `--proxy-on=auto:max`) for one-shot use.
                      Overrides both config file and env var.
  --doctor            Run end-to-end diagnostics: claude on PATH, python3
                      available, proxy script present, config readable
                      and validated, secret reference resolvable, API key
                      live, tier-collision warnings. Prints a checklist
                      then exits.
  --version, -V       Print claude-ds version, plus `claude --version`.
  --help, -h          Print this help, then forward to `claude --help`.

FIRST-RUN BEHAVIOR
  The first invocation (no config file present) prompts for a secret
  reference and writes:
    ${XDG_CONFIG_HOME:-$HOME/.config}/claude-ds/config   (mode 0600)

  Typing `system://` (with or without a trailing account name — any
  trailing input is ignored) drops into an interactive selector that
  scans the OS keychain for entries under service='claude-ds' and lets
  you pick one or create a new account. If the chosen account already
  has a stored secret it is reused; otherwise you are prompted for the
  key and it is stored. The chosen account is persisted as
  `system://<account>` in the config file.

  Surrounding ' or " quotes on entered references are stripped. All
  visible prompts use readline editing (left/right arrows, ctrl-a/e,
  backspace, etc.).

SUPPORTED SECRET-REFERENCE SCHEMES
  op://VAULT/ITEM/FIELD               1Password CLI (`op read`).
                                      e.g. op://Private/Deepseek/credential

  system://                           OS keychain. macOS `security`, Linux
                                      `secret-tool` (install libsecret-tools).
                                      Service name is always `claude-ds`.
                                      Type just `system://` — claude-ds
                                      will list existing entries (if any)
                                      and let you pick or create one
                                      interactively. The chosen account is
                                      persisted as `system://<account>` in
                                      the config file.

  infisical://  (or just `infisical`) Infisical CLI (`infisical secrets get`).
                                      Type just `infisical://` to walk an
                                      interactive builder (project id, env
                                      slug, path, secret key). Or paste a
                                      complete URI:
                                        infisical://PROJECT/ENV/PATH#KEY
                                      e.g. infisical://abc123/prod/#API_KEY
                                      e.g. infisical://abc123/dev/db#PASSWORD
                                      Requires `infisical login` once or
                                      `INFISICAL_TOKEN` exported.

  <key>                               Bare key — anything that doesn't match
                                      a recognised scheme is treated as
                                      plaintext and written to the config
                                      file as-is.

  Shorthand: for `system`, `op`, and `infisical` you may omit the `://` —
  it is appended automatically (so typing `infisical` is equivalent to
  `infisical://` and triggers the interactive builder).

CONFIGURATION
  Config file:  ${XDG_CONFIG_HOME:-$HOME/.config}/claude-ds/config
  Schema:       _schema=1 (auto-migrated forward; old configs are backed
                up to <config>.v0.bak before being upgraded). Damaged
                configs are detected on load, backed up to
                <config>.broken.<timestamp>.bak, and auto-repaired
                preserving every parseable key.
  Keys:         api_key_ref, base_url, model,
                model_opus, model_sonnet, model_haiku, model_small_fast,
                capabilities, unlock_auto_mode,
                proxy_effort, proxy_effort_{opus,sonnet,haiku,small_fast},
                proxy_bind, proxy_debug
  Defaults:     base_url=https://api.deepseek.com/anthropic
                model=deepseek-v4-pro
                model_{opus,sonnet,haiku,small_fast} = <model>
                capabilities = (unset; opt-in)
                unlock_auto_mode = (unset; opt-in)
                proxy_effort = off     (proxy disabled by default — enable with `auto` or a spec)
                proxy_effort_<tier> = (unset; falls through to proxy_effort)
                proxy_bind = 127.0.0.1
                proxy_debug = 0

REASONING-EFFORT PROXY
  DeepSeek's compat shim recognises only three reasoning regimes:
    none    — `thinking` block ABSENT, no `reasoning_effort`. No reasoning.
    high    — `thinking: {type: enabled}` PRESENT, no `reasoning_effort`.
              DeepSeek's default reasoning depth.
    max     — `thinking` PRESENT AND `reasoning_effort=max`. Maximum depth.

  Anthropic's wire format uses `thinking.budget_tokens` (an integer).
  Claude Code has its own `/effort` levels (low/medium/high/xhigh/max)
  that it translates into `thinking.budget_tokens` — but DeepSeek does
  NOT understand most of these levels and would reject them. The claude-ds
  proxy bridges this gap by translating Claude's wire format into one
  of DeepSeek's three regimes.

  ┌──────────────────────────────────────────────────────────────────┐
  │              Claude → DeepSeek effort mapping                    │
  ├─────────────────────────┬────────────────────────────────────────┤
  │  Claude `/effort` level │  DS regime (proxy_effort=auto)         │
  ├─────────────────────────┼────────────────────────────────────────┤
  │  off (no thinking)      │  none — no reasoning tokens            │
  │  low                    │  high — default reasoning              │
  │  medium                 │  high — default reasoning              │
  │  high                   │  high — default reasoning              │
  │  extra-high (xhigh)     │  max  — maximum reasoning              │
  │  max                    │  max  — maximum reasoning              │
  └─────────────────────────┴────────────────────────────────────────┘

  The proxy determines which source bucket a request falls into based
  on `thinking.budget_tokens`:
    budget absent or `type: disabled`  → "none"  (no reasoning)
    budget present, value < 31k        → "high"  (default reasoning)
    budget present, value >= 31k       → "max"   (maximum reasoning)

  Recommended config:
    proxy_effort=auto               # enable + auto-bucket
    proxy_effort_small_fast=none    # never reason on the cheap tier

  Per-tier overrides bind a spec to the *wire-level* model id of that
  tier (the value of ANTHROPIC_DEFAULT_<TIER>_MODEL). Tier specs are
  applied in order small_fast → haiku → sonnet → opus, so opus wins on
  wire-id collisions. If a collision is detected at startup, claude-ds
  prints a one-line linter warning naming the colliding tiers.

  Spec language (config value of proxy_effort or proxy_effort_<tier>):
    auto             — derive regime from claude's thinking (see table)
    auto:<level>     — same with fallback when claude sends no thinking
                       (e.g. `auto:high` → always at least default depth;
                       `auto:max` → always max reasoning)
    off              — pass the body through unchanged for this model
    none             — strip thinking, return non-reasoning response
    high             — force thinking enabled (no reasoning_effort)
    max              — force thinking + reasoning_effort=max
    none=<v>|high=<v>|max=<v>
                     — per-source-bucket matrix. Each clause maps a
                       source bucket to a target regime; unlisted buckets
                       pass through unchanged.
                       Example: `none=high|high=max|max=max` means
                       "no thinking → high; thinking <31k → max;
                       thinking >=31k → max" (i.e. always at least high,
                       and any thinking-enabled request gets max).

  Disable the proxy entirely by setting `proxy_effort=off` and leaving
  every per-tier `proxy_effort_*` unset (or off). Then claude talks to
  DeepSeek directly, no python child involved.

  Env-var overrides (one-shot, no config edit):
    CLAUDE_DS_PROXY_EFFORT=off       skip the proxy for this invocation
    CLAUDE_DS_PROXY_DEBUG=1          log regime injections to stderr

UNLOCKING AUTO MODE (--auto / permission classifier)
  Claude Code's "auto mode" — the permission classifier that auto-approves
  routine tool calls — is gated on the model id matching one of:
    claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6
  The provider is NOT checked (firstParty is the default `tq()` value when
  no CLAUDE_CODE_USE_* is set), but the model name regex is. So with the
  default `model=deepseek-v4-pro`, auto mode reports "unavailable for this
  model".

  Setting `unlock_auto_mode=1` in config makes claude-ds advertise the
  models to claude under Anthropic-canonical names so the regex passes:
    ANTHROPIC_MODEL=claude-opus-4-7
    ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
    ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
    ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
    ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5
    ANTHROPIC_DEFAULT_*_MODEL_NAME / _DESCRIPTION (DeepSeek-labelled, so
                                     the /model picker still shows what's
                                     actually running)
  Whether this works depends on whether your gateway (DeepSeek's
  Anthropic-compat shim) accepts arbitrary `model` values in the request
  body (most compat shims route by URL+auth and ignore model name, or
  alias claude-* IDs to their own model). If DeepSeek rejects the spoofed
  model id, leave `unlock_auto_mode` unset and run without auto mode.

  Per-tier `model_*` config keys, when set, override the spoofed values
  for that tier — escape hatch if you want auto-mode unlock for opus
  (which the gate actually checks) but real DeepSeek IDs for the other
  tiers.

  Sets these env vars before exec'ing `claude`:
    ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN, ANTHROPIC_MODEL,
    ANTHROPIC_DEFAULT_OPUS_MODEL, ANTHROPIC_DEFAULT_SONNET_MODEL,
    ANTHROPIC_DEFAULT_HAIKU_MODEL, ANTHROPIC_SMALL_FAST_MODEL,
    ANTHROPIC_DEFAULT_{OPUS,SONNET,HAIKU}_MODEL_SUPPORTED_CAPABILITIES
      (only when `capabilities=` is set in config — comma-separated list,
       e.g. `effort,thinking,adaptive_thinking,interleaved_thinking`),
    CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1,
    CLAUDE_DISABLE_NONSTREAMING_FALLBACK=1

EOF
        print_rule
        echo "\`claude --help\` follows:"
        echo
        claude --help 2>&1 || true
      } | eval "$pager"
      exit 0
      ;;
  esac
done

# ============================================================================
# BEGIN secretref — reusable secret-reference resolver library
# ----------------------------------------------------------------------------
# Drop-in for any wrapper that needs to fetch a secret from one of:
#   <bare>                              plaintext (anything unrecognised)
#   op://VAULT/ITEM/FIELD               1Password CLI
#   system://<account>                  OS keychain (macOS security / Linux secret-tool)
#   infisical://PROJECT/ENV/PATH#KEY    Infisical CLI
#
# To reuse in another wrapper:
#   1. Copy this BEGIN…END block verbatim.
#   2. Before the block, set:
#        SECRETREF_KEYCHAIN_SERVICE="<your-wrapper-name>"   # required for system://
#        SECRETREF_LOG_PREFIX="<your-wrapper-name>"         # optional (default: secretref)
#   3. Then call:
#        token=$(secretref_resolve "$ref")          # main resolver
#        ref=$(secretref_prompt "API key for foo")  # interactive first-run prompt
#        secretref_help_text                        # supported-schemes doc block
#        secretref_reset_local "$old_ref"           # clean up local secret on reset
#
# To add a new scheme: extend secretref_resolve's case block AND mirror the
# entry in secretref_help_text so consumers' --help stays accurate.
# ----------------------------------------------------------------------------

: "${SECRETREF_LOG_PREFIX:=secretref}"

_secretref_log() { echo "${SECRETREF_LOG_PREFIX}: $*" >&2; }
_secretref_die() { _secretref_log "$@"; exit 1; }
_secretref_require_service() {
  [[ -n "${SECRETREF_KEYCHAIN_SERVICE:-}" ]] \
    || _secretref_die "system:// requires SECRETREF_KEYCHAIN_SERVICE to be set"
}

secretref_keychain_store() {
  _secretref_require_service
  local account="$1" secret="$2"
  case "$(uname -s)" in
    Darwin)
      security add-generic-password -U -s "$SECRETREF_KEYCHAIN_SERVICE" -a "$account" -w "$secret" >/dev/null
      ;;
    Linux)
      command -v secret-tool >/dev/null \
        || _secretref_die "secret-tool not found (install libsecret-tools)"
      printf '%s' "$secret" | secret-tool store --label="$SECRETREF_KEYCHAIN_SERVICE secret" service "$SECRETREF_KEYCHAIN_SERVICE" account "$account"
      ;;
    *) _secretref_die "system:// not supported on $(uname -s)" ;;
  esac
}

secretref_keychain_lookup() {
  _secretref_require_service
  local account="$1"
  case "$(uname -s)" in
    Darwin) security find-generic-password -s "$SECRETREF_KEYCHAIN_SERVICE" -a "$account" -w ;;
    Linux)  secret-tool lookup service "$SECRETREF_KEYCHAIN_SERVICE" account "$account" ;;
    *)      _secretref_die "system:// not supported on $(uname -s)" ;;
  esac
}

secretref_keychain_delete() {
  _secretref_require_service
  local account="$1"
  case "$(uname -s)" in
    Darwin) security delete-generic-password -s "$SECRETREF_KEYCHAIN_SERVICE" -a "$account" >/dev/null 2>&1 || true ;;
    Linux)  secret-tool clear service "$SECRETREF_KEYCHAIN_SERVICE" account "$account" 2>/dev/null || true ;;
  esac
}

# Enumerate accounts already stored under SECRETREF_KEYCHAIN_SERVICE.
# Echoes one account name per line (sorted, unique). Empty output if none.
# macOS: parses `security dump-keychain` (may trigger a one-time keychain-
#        access prompt; failures are silently empty).
# Linux: uses `secret-tool search --all`.
secretref_keychain_list_accounts() {
  _secretref_require_service
  case "$(uname -s)" in
    Darwin)
      security dump-keychain 2>/dev/null | awk -v svc="$SECRETREF_KEYCHAIN_SERVICE" '
        BEGIN { RS="keychain: " }
        index($0, "\"svce\"<blob>=\"" svc "\"") > 0 {
          if (match($0, /"acct"<blob>="[^"]*"/)) {
            # match is `"acct"<blob>="<value>"` — strip 14-char prefix + 1-char suffix.
            a = substr($0, RSTART+14, RLENGTH-15)
            if (a != "") print a
          }
        }
      ' | sort -u
      ;;
    Linux)
      command -v secret-tool >/dev/null || return 0
      secret-tool search --all service "$SECRETREF_KEYCHAIN_SERVICE" 2>/dev/null \
        | awk -F' = ' '$1=="attribute.account"{print $2}' \
        | sort -u
      ;;
    *) return 0 ;;
  esac
}

# Strip a single layer of matching ASCII single- or double-quotes from $1.
# Trailing/leading whitespace is left alone — we only unwrap exact quote pairs.
_secretref_strip_quotes() {
  local s="$1"
  case "$s" in
    \'*\') s="${s#\'}"; s="${s%\'}" ;;
    \"*\") s="${s#\"}"; s="${s%\"}" ;;
  esac
  printf '%s' "$s"
}

# Read a secret from the terminal, echoing '*' for each character typed.
# Prints the secret to stdout.
_secretref_read_secret() {
  local secret="" char
  stty -echo
  while IFS= read -r -n 1 char; do
    if [[ -z "$char" ]] || [[ "$char" == $'\n' ]]; then
      printf '\n' >&2
      break
    elif [[ "$char" == $'\177' ]] || [[ "$char" == $'\b' ]]; then
      if [[ -n "$secret" ]]; then
        secret="${secret%?}"
        printf '\b \b' >&2
      fi
    else
      secret+="$char"
      printf '*' >&2
    fi
  done
  stty echo
  printf '%s' "$secret"
}

# Allow bare scheme names without `://` — `system` ≡ `system://`,
# `op` ≡ `op://`, `infisical` ≡ `infisical://`. Anything else passes through.
_secretref_canonicalize_scheme() {
  case "$1" in
    system|op|infisical) printf '%s://' "$1" ;;
    *) printf '%s' "$1" ;;
  esac
}

# Interactive walkthrough for an `infisical://PROJECT/ENV/PATH#KEY` reference.
# Prompts for each component, normalizes the path (strips leading/trailing
# slashes, empty == root), and echoes the constructed URI.
secretref_build_infisical_ref() {
  {
    echo
    echo "Build an infisical:// reference interactively."
    echo "  See https://infisical.com/docs/cli/commands/secrets for project/env conventions."
  } >&2
  local proj env_slug folder key
  printf "Project ID: " >&2
  IFS= read -e -r proj
  proj=$(_secretref_strip_quotes "$proj")
  [[ -n "$proj" ]] || _secretref_die "empty project id, aborting."

  printf "Environment slug [dev]: " >&2
  IFS= read -e -r env_slug
  env_slug=$(_secretref_strip_quotes "$env_slug")
  env_slug="${env_slug:-dev}"

  printf "Folder path ('/' for root) [/]: " >&2
  IFS= read -e -r folder
  folder=$(_secretref_strip_quotes "$folder")
  folder="${folder:-/}"
  # Normalize: strip leading + trailing slashes; empty means root.
  folder="${folder#/}"
  folder="${folder%/}"

  printf "Secret key (name of the secret in Infisical): " >&2
  IFS= read -e -r key
  key=$(_secretref_strip_quotes "$key")
  [[ -n "$key" ]] || _secretref_die "empty secret key, aborting."

  if [[ -z "$folder" ]]; then
    printf 'infisical://%s/%s/#%s' "$proj" "$env_slug" "$key"
  else
    printf 'infisical://%s/%s/%s#%s' "$proj" "$env_slug" "$folder" "$key"
  fi
}

# Interactive selector for a system:// account name. If existing entries are
# stored under SECRETREF_KEYCHAIN_SERVICE, presents them as a numbered list
# and lets the user pick by number, type a free-form new name, or accept the
# default (new). Echoes the chosen account name to stdout.
secretref_select_account() {
  _secretref_require_service
  local accounts=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && accounts+=("$line")
  done < <(secretref_keychain_list_accounts)

  if [[ ${#accounts[@]} -gt 0 ]]; then
    {
      echo
      echo "Existing keychain entries for service='$SECRETREF_KEYCHAIN_SERVICE':"
      local i=1
      for a in "${accounts[@]}"; do
        printf "  [%d] %s\n" "$i" "$a"
        ((i++))
      done
      echo "  [n] Enter a new account name"
    } >&2
    printf "Choice (number, 'n' for new, or type the account name directly): " >&2
    local choice
    IFS= read -e -r choice
    choice=$(_secretref_strip_quotes "$choice")
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#accounts[@]} )); then
      printf '%s' "${accounts[$((choice-1))]}"
      return 0
    fi
    if [[ -z "$choice" || "$choice" == "n" || "$choice" == "N" ]]; then
      printf "New account name: " >&2
      local name
      IFS= read -e -r name
      name=$(_secretref_strip_quotes "$name")
      [[ -n "$name" ]] || _secretref_die "empty account name"
      printf '%s' "$name"
      return 0
    fi
    # Treat free-form input as a new (or existing) account name.
    printf '%s' "$choice"
  else
    {
      echo
      echo "No existing keychain entries for service='$SECRETREF_KEYCHAIN_SERVICE'."
    } >&2
    printf "New account name: " >&2
    local name
    IFS= read -e -r name
    name=$(_secretref_strip_quotes "$name")
    [[ -n "$name" ]] || _secretref_die "empty account name"
    printf '%s' "$name"
  fi
}

secretref_resolve() {
  local ref="$1"
  case "$ref" in
    op://*)
      command -v op >/dev/null || _secretref_die "op CLI not found (install 1Password CLI)"
      op read -- "$ref"
      ;;
    system://*)
      secretref_keychain_lookup "${ref#system://}"
      ;;
    infisical://*)
      command -v infisical >/dev/null || _secretref_die "infisical CLI not found (install Infisical CLI)"
      local rest="${ref#infisical://}"
      case "$rest" in
        *\#*) ;;
        *) _secretref_die "infisical:// requires #SECRET_KEY fragment (e.g. infisical://PROJECT/ENV/PATH#KEY)" ;;
      esac
      local key="${rest##*#}"
      rest="${rest%#*}"
      case "$rest" in
        */*/*) ;;
        *) _secretref_die "infisical:// requires PROJECT_ID/ENV/PATH (got '$rest')" ;;
      esac
      local proj="${rest%%/*}"
      rest="${rest#*/}"
      local env="${rest%%/*}"
      local path
      if [[ "$rest" == "$env" || "$rest" == "$env/" ]]; then
        path="/"
      else
        path="/${rest#*/}"
        path="${path%/}"
        [[ -n "$path" ]] || path="/"
      fi
      [[ -n "$proj" && -n "$env" && -n "$key" ]] || _secretref_die "infisical:// missing project/env/key"
      infisical secrets get "$key" --projectId="$proj" --env="$env" --path="$path" --plain --silent
      ;;
    # Add future schemes here, e.g.:
    # warden://ITEM)        bw get password "${ref#warden://}" ;;
    *)
      printf '%s' "$ref"
      ;;
  esac
}

# Print the supported-schemes documentation block to stdout. Embeds the
# current SECRETREF_KEYCHAIN_SERVICE so help text reflects the consumer.
secretref_help_text() {
  cat <<EOF
  op://VAULT/ITEM/FIELD               1Password CLI ('op read').
                                      e.g. op://Private/Service/credential

  system://  (or just 'system')       OS keychain. macOS 'security', Linux
                                      'secret-tool' (install libsecret-tools).
                                      Service name: '${SECRETREF_KEYCHAIN_SERVICE:-<unset>}'.
                                      Type just 'system://' — claude-ds
                                      lists existing entries (if any) for
                                      this service and lets you pick one
                                      or create a new one interactively.

  infisical://  (or just 'infisical') Infisical CLI ('infisical secrets get').
                                      Type just 'infisical://' to get an
                                      interactive walkthrough that asks for
                                      project ID, env slug, folder path,
                                      and secret key, then builds the full
                                      URI for you. Or paste a complete URI:
                                        infisical://PROJECT/ENV/PATH#KEY
                                      Requires 'infisical login' once or
                                      INFISICAL_TOKEN exported in the env.

  <key>                               Bare key — anything not matching a
                                      recognised scheme is treated as
                                      plaintext.

  Note: for 'system', 'op', and 'infisical' you may omit the '://' suffix
  — the lib appends it automatically.
EOF
}

# Interactive first-run prompt. Arg: human-readable label for the secret being
# configured (e.g. "DeepSeek API key for claude-ds"). Echoes the chosen
# reference to stdout; emits prompts and diagnostics to stderr. For system://
# references, transparently reuses an existing keychain entry or prompts for a
# new key and stores it.
secretref_prompt() {
  local label="${1:-secret}"
  {
    echo "Configure $label."
    echo
    echo "Enter a secret reference. Supported schemes:"
    secretref_help_text
    echo
    echo "(Tip: surrounding ' or \" quotes will be stripped. Use arrow keys to edit.)"
  } >&2
  printf "Reference: " >&2
  local ref
  IFS= read -e -r ref
  ref=$(_secretref_strip_quotes "$ref")
  ref=$(_secretref_canonicalize_scheme "$ref")
  [[ -n "$ref" ]] || _secretref_die "empty reference, aborting."

  # Bare scheme entries → interactive builders.
  if [[ "$ref" == "infisical://" ]]; then
    ref=$(secretref_build_infisical_ref)
  elif [[ "$ref" == "op://" ]]; then
    _secretref_die "op:// requires a VAULT/ITEM/FIELD path (e.g. op://Private/Service/credential). No interactive builder is provided for op://; please re-enter."
  fi

  if [[ "$ref" == system://* ]]; then
    _secretref_require_service
    # Any system://… input drops into the interactive selector. We never
    # accept a free-form `system://<acct>` directly — the selector is the
    # one source of truth for picking an account, so existing entries are
    # always surfaced and accidental new accounts are harder to create.
    local account
    account=$(secretref_select_account)
    ref="system://$account"
    if secretref_keychain_lookup "$account" >/dev/null 2>&1; then
      _secretref_log "found existing keychain entry — service='$SECRETREF_KEYCHAIN_SERVICE', account='$account'. Reusing it."
      _secretref_log "to overwrite, re-run with the wrapper's --reset-password flag."
    else
      printf "No existing keychain entry for service='%s' account='%s'.\nPaste %s (will be stored in %s keychain):\n> " \
        "$SECRETREF_KEYCHAIN_SERVICE" "$account" "$label" "$(uname -s)" >&2
      local secret
      secret=$(_secretref_read_secret)
      [[ -n "$secret" ]] || _secretref_die "empty key, aborting."
      secretref_keychain_store "$account" "$secret"
      _secretref_log "stored secret — service='$SECRETREF_KEYCHAIN_SERVICE', account='$account'."
    fi
  fi

  printf '%s' "$ref"
}

# Interactive --reset-password flow. Args: <old_ref> [<label>]. Echoes the
# new (chosen) ref to stdout.
#
# When old_ref is system://<acct>:
#   [1] Change the API key for <acct> — keep account name, prompt for a new
#       secret value, overwrite the keychain entry. Returns the same ref.
#   [2] Switch to a different account / scheme — ask whether to delete or
#       keep the old keychain entry, then run a fresh secretref_prompt.
#
# For non-system schemes, just runs secretref_reset_local (logs that the
# upstream store is untouched) and re-prompts.
secretref_reset_interactive() {
  local old_ref="$1" label="${2:-secret}"

  if [[ "$old_ref" == system://* ]]; then
    _secretref_require_service
    local old_acct="${old_ref#system://}"
    {
      echo
      echo "Existing reference is system://$old_acct (service='$SECRETREF_KEYCHAIN_SERVICE')."
      echo "  [1] Change the $label for '$old_acct' (keep account, replace stored secret)"
      echo "  [2] Switch to a different account / scheme"
    } >&2
    printf "Choice [1/2, default 1]: " >&2
    local choice
    IFS= read -e -r choice
    choice=$(_secretref_strip_quotes "$choice")
    case "${choice:-1}" in
      1)
        printf "Paste new %s for account='%s' (will overwrite %s keychain entry):\n> " \
          "$label" "$old_acct" "$(uname -s)" >&2
        local secret
        secret=$(_secretref_read_secret)
        [[ -n "$secret" ]] || _secretref_die "empty key, aborting."
        secretref_keychain_store "$old_acct" "$secret"
        _secretref_log "updated keychain entry — service='$SECRETREF_KEYCHAIN_SERVICE', account='$old_acct'."
        printf '%s' "$old_ref"
        return 0
        ;;
      2)
        printf "Delete existing keychain entry service='%s' account='%s'? [y/N]: " \
          "$SECRETREF_KEYCHAIN_SERVICE" "$old_acct" >&2
        local del
        IFS= read -e -r del
        del=$(_secretref_strip_quotes "$del")
        if [[ "$del" =~ ^[yY] ]]; then
          secretref_keychain_delete "$old_acct"
          _secretref_log "deleted keychain entry — service='$SECRETREF_KEYCHAIN_SERVICE', account='$old_acct'."
        else
          _secretref_log "kept keychain entry — service='$SECRETREF_KEYCHAIN_SERVICE', account='$old_acct'."
        fi
        secretref_prompt "$label"
        return 0
        ;;
      *)
        _secretref_die "invalid choice '$choice'"
        ;;
    esac
  fi

  secretref_reset_local "$old_ref"
  secretref_prompt "$label"
}

# Clean up any local secret associated with a reference (for --reset-password).
# Only system:// has a local secret; for other schemes, just emits an
# informational log line so the user knows the upstream store is untouched.
secretref_reset_local() {
  local ref="$1"
  if [[ "$ref" == system://* ]]; then
    _secretref_require_service
    local account="${ref#system://}"
    _secretref_log "  removing $(uname -s) keychain entry — service='$SECRETREF_KEYCHAIN_SERVICE', account='$account'."
    secretref_keychain_delete "$account"
  elif [[ -n "$ref" ]]; then
    _secretref_log "  prior reference was '$ref' (no local secret to delete — only the reference is forgotten)."
  fi
}

